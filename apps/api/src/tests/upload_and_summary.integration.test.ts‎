// apps/api/src/tests/upload_and_summary.integration.test.ts
import { describe, it, expect, beforeAll, afterAll } from "vitest";
import { MongoMemoryServer } from "mongodb-memory-server";
import { startApiWithEnv } from "./testServer";
import jwt from "jsonwebtoken";
import JSZip from "jszip";

let mongod: MongoMemoryServer;
let uri: string;
let stopServer: () => Promise<void>;

const JWT = `jwt-${Date.now()}`;
const userId = "u-upload";
const bearer = () => ({
  Authorization: "Bearer " + jwt.sign({ userId }, JWT),
});

function makeValidZip(): Promise<Uint8Array> {
  const zip = new JSZip();
  const records = [
    {
      ts: "2024-01-02T12:00:00Z",
      ms_played: 180000,
      master_metadata_track_name: "Song A",
      master_metadata_album_artist_name: "Artist A",
      master_metadata_album_album_name: "Album A",
      spotify_track_uri: "spotify:track:abc",

      platform: "",
      conn_country: "",
      ip_addr: "",
      episode_name: "",
      episode_show_name: "",
      spotify_episode_uri: "",
      audiobook_title: "",
      audiobook_uri: "",
      audiobook_chapter_uri: "",
      audiobook_chapter_title: "",
      reason_start: "",
      reason_end: "",
      shuffle: false,
      skipped: false,
      offline: false,
      offline_timestamp: 0,
      incognito_mode: false
    }
  ];

  zip.file("MyData/StreamingHistory_audio_0.json", JSON.stringify(records));
  return zip.generateAsync({ type: "uint8array" });
}

describe.sequential("Integration: upload zip -> summary", () => {
  beforeAll(async () => {
    mongod = await MongoMemoryServer.create();
    uri = mongod.getUri();
    stopServer = await startApiWithEnv({ MONGODB_URI: uri, JWT_SECRET: JWT });
  });

  afterAll(async () => {
    await stopServer?.();
    await mongod?.stop();
  });

  it.skip("stores quality streams and returns non-empty summary", async () => {
    const zipBytes = await makeValidZip();
    const file = new File([zipBytes], "spotify.zip", { type: "application/zip" });

    const form = new FormData();
    form.append("file", file);

    const up = await fetch("http://localhost:3000/upload", {
      method: "POST",
      headers: bearer(),
      body: form,
    });

    expect(up.status).toBe(200);
    const upBody = await up.json();
    expect(upBody.success).toBe(true);
    expect(upBody.qualityStreams).toBeGreaterThan(0);
    expect(typeof upBody.uploadId).toBe("string");

    const summary = await fetch("http://localhost:3000/stats/summary", {
      headers: bearer(),
    });
    expect(summary.status).toBe(200);
    const sBody = await summary.json();
    expect(sBody.success).toBe(true);
    expect(sBody.data.totalTracks).toBeGreaterThan(0);
    expect(sBody.data.totalHours).toBeGreaterThan(0);
  });
});